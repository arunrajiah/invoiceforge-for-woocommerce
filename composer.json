{
    "name": "invoiceforge/invoiceforge-for-woocommerce",
    "description": "PDF invoices and packing slips for WooCommerce — Free plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "mpdf/mpdf": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.0",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcsstandards/phpcsutils": "^1.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "classmap": [
            "includes/"
        ],
        "files": [
            "includes/helpers/functions.php"
        ],
        "exclude-from-classmap": [
            "includes/helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/phpunit/"
        ]
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint-fix": "phpcbf --standard=phpcs.xml.dist",
        "test": "phpunit --configuration phpunit.xml.dist"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "installer-paths": {}
    }
}

<?xml version="1.0"?>
<ruleset name="InvoiceForge PHPCS">
    <description>WordPress Extra coding standards for InvoiceForge.</description>

    <file>.</file>
    <!-- Use */vendor/* so PHPCS matches vendor/ against the absolute path in CI. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <!-- Templates are view files; variables come from extract() and follow HTML patterns. -->
    <exclude-pattern>*/templates/*</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>

    <rule ref="WordPress-Extra">
        <!--
            Short array syntax [] is valid PHP 5.4+ and used throughout WP core since 5.6.
            We target PHP 7.4+ so there is no compatibility concern.
        -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <!--
            Short ternary ?: is commonly used in WP template code; excluding since
            the DisallowShortTernary rule does not match our style guide.
        -->
        <exclude name="Universal.Operators.DisallowShortTernary"/>
    </rule>
    <rule ref="WordPress-Docs">
        <!--
            Requiring docblocks on every private/short method creates noise when
            method names and typed params are already self-describing.
        -->
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Generic.Commenting.DocComment.MissingShort"/>
    </rule>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="invoiceforge"/>
                <element value="InvoiceForge"/>
                <element value="INVOICEFORGE"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="invoiceforge-for-woocommerce"/>
            </property>
        </properties>
    </rule>

    <!-- Register manage_woocommerce as a known custom capability. -->
    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="manage_woocommerce"/>
            </property>
        </properties>
    </rule>

    <!-- Minimum PHP version. -->
    <config name="minimum_supported_wp_version" value="6.2"/>
    <config name="testVersion" value="7.4-"/>
</ruleset>

<?xml version="1.0"?>
<ruleset name="InvoiceForge PHPCS">
    <description>WordPress Extra coding standards for InvoiceForge.</description>

    <file>.</file>
    <!-- Use */vendor/* (not vendor/*) so PHPCS matches vendor/ anywhere in the absolute path. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <!-- Templates are view files; variables come from extract() and follow HTML patterns. -->
    <exclude-pattern>*/templates/*</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>

    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="invoiceforge"/>
                <element value="InvoiceForge"/>
                <element value="INVOICEFORGE"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="invoiceforge-for-woocommerce"/>
            </property>
        </properties>
    </rule>

    <!--
        Short array syntax [] is valid PHP 5.4+ and used throughout WP core since 5.6.
        Disabling DisallowShortArraySyntax since we target PHP 7.4+.
    -->
    <rule ref="Universal.Arrays.DisallowShortArraySyntax">
        <exclude-pattern>*</exclude-pattern>
    </rule>

    <!--
        Requiring docblocks on every private/internal method creates noise without
        improving readability when method names and typed params are self-describing.
        We keep file and class-level docblocks (WordPress-Docs) but relax method-level.
    -->
    <rule ref="Squiz.Commenting.FunctionComment.Missing">
        <exclude-pattern>*</exclude-pattern>
    </rule>
    <rule ref="Generic.Commenting.DocComment.MissingShort">
        <exclude-pattern>*</exclude-pattern>
    </rule>

    <!-- Minimum PHP version. -->
    <config name="minimum_supported_wp_version" value="6.2"/>
    <config name="testVersion" value="7.4-"/>
</ruleset>
